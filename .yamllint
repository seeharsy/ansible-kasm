---
extends: default
rules:
  line-length:
    max: 160
    level: warning
  colons:
    max-spaces-before: 0
    max-spaces-after: -1
  comments-indentation: disable
  comments:
    min-spaces-from-content: 1
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
